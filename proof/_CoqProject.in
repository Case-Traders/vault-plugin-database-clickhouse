-Q @PLUGIN_ROOT@/proof/goose/code New.code
-Q @PLUGIN_ROOT@/proof/goose/generatedproof New.generatedproof
-Q @PERENNIAL_ROOT@/new/code New.code
-Q @PERENNIAL_ROOT@/new/generatedproof New.generatedproof
-R @PERENNIAL_ROOT@/src Perennial
-R @PERENNIAL_ROOT@/new New
-Q @PLUGIN_ROOT@/proof/clickhouse ClickhouseProof
goose/code/vault_plugin_database_clickhouse/internal/stmt.v
goose/code/vault_plugin_database_clickhouse/internal/cluster/choose.v
goose/code/vault_plugin_database_clickhouse/internal/firsterror.v
goose/code/vault_plugin_database_clickhouse/internal/vars.v
goose/code/vault_plugin_database_clickhouse/internal/validate.v
goose/code/vault_plugin_database_clickhouse/internal/deletepath.v
goose/generatedproof/vault_plugin_database_clickhouse/internal/stmt.v
goose/generatedproof/vault_plugin_database_clickhouse/internal/cluster/choose.v
goose/generatedproof/vault_plugin_database_clickhouse/internal/firsterror.v
goose/generatedproof/vault_plugin_database_clickhouse/internal/vars.v
goose/generatedproof/vault_plugin_database_clickhouse/internal/validate.v
goose/generatedproof/vault_plugin_database_clickhouse/internal/deletepath.v
clickhouse/init.v
clickhouse/stmt_forall.v
clickhouse/choose_forall.v
clickhouse/firsterror_forall.v
clickhouse/vars_forall.v
clickhouse/validate_forall.v
clickhouse/deletepath_forall.v
-arg -w -arg +deprecated-instance-without-locality
-arg -w -arg +ambiguous-paths
-arg -w -arg +deprecated-hint-rewrite-without-locality
-arg -w -arg +deprecated-field-instance-without-locality
-arg -w -arg +deprecated-tactic-notation
-arg -w -arg -deprecated-since-8.19,-deprecated-since-8.20
-arg -w -arg -deprecated-since-9.0,-deprecated-since-9.1,-deprecated-since-9.2
-arg -w -arg -via-type-remapping,-via-type-mismatch
-arg -w -arg +deprecated-typeclasses-transparency-without-locality
-arg -w -arg -notation-overridden,-redundant-canonical-projection,-notation-incompatible-prefix
-arg -w -arg -unknown-warning
-arg -w -arg -postfix-notation-not-level-1,-closed-notation-not-level-0
